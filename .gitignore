# ============================================================
# BreathoMeter3.0 — Combined .gitignore (Node.js + Python)
# ============================================================

# ─── Environment & Secrets ───────────────────────────────────
.env
.env.local
.env.production
.env.staging
*.env
!.env.example

# ─── Node.js / Next.js ───────────────────────────────────────
node_modules/
.next/
out/
build/
dist/
.vercel/
.turbo/
*.tsbuildinfo
next-env.d.ts
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.cache/

# ─── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
.env/
ENV/
pip-log.txt
pip-delete-this-directory.txt
.eggs/
*.egg-info/
dist/
build/
*.egg
.mypy_cache/
.dmypy.json
dmypy.json
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
*.pyo

# ─── ML / Model Artifacts ────────────────────────────────────
ml/models/*.onnx
ml/models/*.pkl
ml/models/*.joblib
ml/models/*.h5
ml/data/raw/
ml/data/processed/
mlruns/
mlartifacts/
*.mlflow

# ─── Jupyter Notebooks ───────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ─── Docker ──────────────────────────────────────────────────
*.dockerignore

# ─── OS Files ────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ─── IDE / Editor ────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ─── Logs ────────────────────────────────────────────────────
logs/
*.log
npm-debug.log
yarn-debug.log

# ─── Testing ─────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Misc ────────────────────────────────────────────────────
*.bak
*.tmp
.temp/
