# ============================================================
# BreathoMeter3.0 — Root Environment Variables Template
# Copy this to .env and fill in your values.
# NEVER commit the .env file.
# ============================================================

# ─── AQI Data APIs ───────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweather_api_key_here
WAQI_API_KEY=your_waqi_api_key_here

# ─── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Backend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000
JWT_SECRET=your_jwt_secret_minimum_32_chars_here

# ─── ML Model Paths ──────────────────────────────────────────
DATASET_PATH=/path/to/your/training_dataset.csv
ML_MODEL_PATH=./ml/models/ensemble.onnx
SCALER_PATH=./ml/models/scaler.pkl

# ─── MLflow Tracking ─────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=breathometer_ensemble

# ─── App Config ──────────────────────────────────────────────
NODE_ENV=development
PYTHON_ENV=development
